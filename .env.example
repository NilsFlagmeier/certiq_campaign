# Copy to .env and fill in real values. Never commit .env.
# This tool runs ONLY on your machine (127.0.0.1). Do not deploy publicly.

# Public site base URL — unsubscribe links in emails must point here
APP_BASE_URL=https://certiq.tech
UNSUBSCRIBE_SECRET=bitte_ein_langes_geheimes_token_setzen

# Local login (generate hash: python scripts/hash_admin_password.py)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD_HASH_B64=
ADMIN_PORTAL_SESSION_SECRET=bitte_langes_session_secret_setzen
ADMIN_SESSION_TTL_SECONDS=43200

# Resend (campaign send)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_EMAIL_API_KEY=
RESEND_CONTACTS_API_KEY=
RESEND_AUDIENCE_ID=
RESEND_FROM="Certiq <hello@certiq.tech>"
INTERNAL_NOTIFY_TO=founders@certiq.tech

# Supabase campaign event store
NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
DATABASE_URL=

# Twenty CRM
TWENTY_API_URL=https://crm.certiq.tech
TWENTY_CRM_API_KEY=
TWENTY_SSL_VERIFY=true
TWENTY_PEOPLE_PAGE_SIZE=60

# Metrics (optional)
ADMIN_METRICS_SITE_URL=https://certiq.tech
GOOGLE_PAGESPEED_API_KEY=
CLARITY_PROJECT_ID=
CLARITY_TOKEN=
GSC_SITE_URL=sc-domain:certiq.tech
GSC_ACCESS_TOKEN=

# Mistral email suggestions (optional)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Lead ingest token (optional, for scripted intake)
ADMIN_INGEST_TOKEN=
